---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { academicProjects, site } from '../../data/site';
import { filterPublished } from '../../lib/content';

const publications = filterPublished(await getCollection('publications'));
const timelineProjects = [
  {
    ...academicProjects[0],
    year: '2026+',
    logo: '/images/academic/COS_Arizona-Cosmology-Lab_WEBHEADER.svg',
    logoClass: 'lab-wordmark',
    media: undefined
  },
  {
    ...academicProjects[1],
    year: '2024',
    logo: '/images/Caltech-logo.png',
    logoClass: 'wide',
    media: {
      src: '/images/academic/spherex-first-light.webp',
      alt: 'Six infrared detector views from a SPHEREx first-light exposure',
      caption: 'One of SPHEREx’s first detector exposures. Image: NASA/JPL-Caltech.'
    }
  },
  {
    ...academicProjects[2],
    year: '2022–24',
    logo: '/images/Duke-logo.png',
    logoClass: 'wide',
    media: {
      src: '/images/academic/openuniverse-roman.webp',
      alt: 'A simulated Roman Space Telescope field from OpenUniverse2024',
      caption: 'A simulated Roman field from OpenUniverse2024. Image: NASA Goddard and M. Troxel.'
    }
  }
] as const;
---

<BaseLayout title="Academic Research" description="Cosmology, statistical inference, scientific machine learning, survey simulations, and publications." variant="academic">
  <div class="academic-legacy-page" id="academic-overview">
    <nav class="academic-page-index" aria-label="Academic page index" data-academic-index>
      <button class="academic-page-index-toggle" type="button" aria-expanded="false" aria-controls="academic-page-index-panel" data-index-toggle>
        <span aria-hidden="true">☰</span>
        <span>Index</span>
      </button>
      <div class="academic-page-index-panel" id="academic-page-index-panel">
        <p>Page / Index</p>
        <ol>
          <li><a href="#academic-overview" data-index-link><span>00</span>Overview</a></li>
          <li><a href="#arizona-bao" data-index-link><span>01</span>Arizona</a></li>
          <li><a href="#caltech-spherex" data-index-link><span>02</span>SPHEREx</a></li>
          <li><a href="#duke-surveys" data-index-link><span>03</span>Duke</a></li>
          <li><a href="#publications" data-index-link><span>04</span>Publications</a></li>
          <li><a href="#education" data-index-link><span>05</span>Education</a></li>
          <li><a href="#academic-contact" data-index-link><span>06</span>Contact</a></li>
        </ol>
      </div>
    </nav>

    <div class="academic-legacy-container">
      <section class="academic-profile" aria-labelledby="academic-profile-name">
        <aside class="academic-profile-aside" aria-label="Profile and contact links">
          <img src="/images/portrait.jpg" alt="Portrait of Tianrui Wu" />
          <div class="academic-social-links">
            <a href={`mailto:${site.email}`} aria-label="Email">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 4H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2Zm0 4-8 5-8-5V6l8 5 8-5v2Z"/></svg>
            </a>
            <a href={site.github} aria-label="GitHub" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.5 11.5 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12Z"/></svg>
            </a>
            <a href={site.linkedin} aria-label="LinkedIn" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 1 1 0-4.124 2.062 2.062 0 0 1 0 4.124ZM7.119 20.452H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/></svg>
            </a>
            <a href={site.cv} aria-label="Academic CV" target="_blank" rel="noopener">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm2 16H8v-2h8v2Zm0-4H8v-2h8v2Zm-3-5V3.5L18.5 9H13Z"/></svg>
            </a>
          </div>
          <div class="academic-document-links">
            <a href="/quant/">Quant profile</a>
            <span aria-hidden="true">·</span>
            <a href={site.cv} target="_blank" rel="noopener">Curriculum vitae</a>
          </div>
        </aside>

        <header class="academic-profile-copy">
          <h1 id="academic-profile-name"><strong>Tianrui (Dennis)</strong> Wu</h1>
          <p class="academic-subtitle">I study cosmology with statistical inference, scientific machine learning, and large survey simulations.</p>
          <div class="academic-description">
            <p>I am pursuing Physics and Mathematics at the University of Arizona and work with the Arizona Cosmology Lab on baryon acoustic oscillation reconstruction under photometric-redshift uncertainty.</p>
            <p>My research builds forward models, Bayesian inference pipelines, and scientific machine-learning systems for next-generation surveys including Roman, Rubin, and SPHEREx.</p>
            <p>Prior work at Caltech and Duke focused on power-spectrum reconstruction, weak lensing, survey synergies, and distance-ladder calibration.</p>
          </div>
        </header>
      </section>

      <div class="academic-section-rule" aria-hidden="true"></div>

      <section class="academic-research-section" aria-label="Academic research timeline">
        <div class="academic-timeline">
          {timelineProjects.map((project) => (
            <article class="academic-timeline-item" id={project.id}>
              <span class="academic-timeline-date">{project.year}</span>
              <div class="academic-timeline-content">
                <h2 class="academic-title-with-logo">
                  {project.title}
                  <span class="academic-institution-logo">
                    <img class:list={[project.logoClass]} src={project.logo} alt="" />
                  </span>
                </h2>
                <p class="academic-institution">{project.institution}</p>
                <ul>
                  <li><strong>Question.</strong> {project.problem}</li>
                  <li><strong>Data.</strong> {project.data}</li>
                  <li><strong>Built.</strong> {project.contribution}</li>
                  <li><strong>Result.</strong> {project.result}</li>
                </ul>
                {project.media && (
                  <figure class="academic-media-module">
                    <img src={project.media.src} alt={project.media.alt} loading="lazy" />
                    <figcaption>{project.media.caption}</figcaption>
                  </figure>
                )}
              </div>
            </article>
          ))}

          <article class="academic-timeline-item" id="publications">
            <span class="academic-timeline-date">Papers</span>
            <div class="academic-timeline-content">
              <h2>Selected publications</h2>
              <div class="academic-publication-list">
                {publications.map((publication) => (
                  <a href={`/academic/publications/${publication.data.slug}/`}>
                    <span>{publication.data.venue}</span>
                    <strong>{publication.data.title}</strong>
                    <small>{publication.data.citation}</small>
                  </a>
                ))}
              </div>
            </div>
          </article>

          <article class="academic-timeline-item" id="education">
            <span class="academic-timeline-date">2021–27</span>
            <div class="academic-timeline-content">
              <h2>Physics, mathematics, teaching, and leadership</h2>
              <p>I am pursuing a double major in Physics and Mathematics at the University of Arizona, following prior study and research at Duke University.</p>
              <p>The complete education, teaching, service, leadership, and recognition record is preserved in the downloadable academic CV.</p>
              <div class="academic-logo-strip" aria-label="Selected organizations">
                <img src="/images/Duke-logo.png" alt="Duke University" />
                <img src="/images/SPS-logo.png" alt="Society of Physics Students" />
                <img src="/images/stargazing-logo.png" alt="Stargazing Devils" />
                <img src="/images/APS-logo.jpg" alt="American Physical Society" />
              </div>
            </div>
          </article>

          <article class="academic-timeline-item academic-contact-item" id="academic-contact">
            <span class="academic-timeline-date">Now</span>
            <div class="academic-timeline-content">
              <h2>Contact</h2>
              <p>Reach me at <a href={`mailto:${site.email}`}>{site.email}</a>, connect on <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>, or view my work on <a href={site.github} target="_blank" rel="noopener">GitHub</a>.</p>
            </div>
          </article>
        </div>
      </section>

      <footer class="academic-image-credits">
        Background imagery: JWST Cosmic Cliffs and Pillars of Creation. NASA, ESA, CSA, and STScI.
      </footer>
    </div>
  </div>

  <script>
    const index = document.querySelector<HTMLElement>('[data-academic-index]');
    const toggle = index?.querySelector<HTMLButtonElement>('[data-index-toggle]');
    const links = Array.from(index?.querySelectorAll<HTMLAnchorElement>('[data-index-link]') ?? []);
    const sections = links.map((link) => document.querySelector<HTMLElement>(link.hash)).filter(Boolean) as HTMLElement[];

    toggle?.addEventListener('click', () => {
      const isOpen = index?.classList.toggle('is-open') ?? false;
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    links.forEach((link) => link.addEventListener('click', () => {
      index?.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
    }));

    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((entry) => entry.isIntersecting).sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];
      if (!visible) return;
      links.forEach((link) => link.toggleAttribute('aria-current', link.hash === `#${visible.target.id}`));
    }, { rootMargin: '-18% 0px -68% 0px', threshold: [0, 0.25, 0.6] });

    sections.forEach((section) => observer.observe(section));
  </script>

  <style is:global>
    html:has(body[data-theme='academic']) {
      color-scheme: dark;
      background: #050711;
    }

    body[data-theme='academic'] {
      --void: #050711;
      --void-2: #090d1e;
      --surface: rgba(7, 11, 27, .78);
      --surface-solid: #0a1025;
      --surface-raised: rgba(17, 25, 52, .9);
      --signal: #f0cc72;
      --signal-rgb: 240, 204, 114;
      --positive: #b9c7ff;
      --warning: #ffd690;
      --text: #f7f8ff;
      --text-soft: #c5cbe0;
      --line: rgba(255, 255, 255, .18);
      --line-strong: rgba(240, 204, 114, .5);
      --display: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      --body: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      color: var(--text);
      background: #050711;
    }

    body[data-theme='academic'] .site-header {
      border-color: rgba(255, 255, 255, .16);
      background: rgba(5, 7, 17, .84);
    }

    body[data-theme='academic'] .brand-mark {
      border-radius: 3px;
    }

    body[data-theme='academic'] .site-footer {
      border-top: 1px solid rgba(255, 255, 255, .16);
      color: var(--text);
      background: rgba(5, 7, 17, .92);
    }

    body[data-theme='academic'] .footer-bottom {
      border-color: rgba(255, 255, 255, .14);
    }

    .academic-legacy-page {
      position: relative;
      min-height: 100vh;
      overflow: hidden;
      padding: 1px 0 54px;
      color: var(--text);
      background:
        linear-gradient(180deg, rgba(3, 5, 14, .56), rgba(3, 6, 17, .8)),
        url('/images/academic/jwst-cosmic-cliffs.webp') center top / cover no-repeat;
    }

    .academic-legacy-container {
      position: relative;
      z-index: 1;
      width: min(1100px, calc(100% - 40px));
      margin-inline: auto;
    }

    .academic-profile {
      position: relative;
      margin-top: 76px;
    }

    .academic-profile::after {
      display: table;
      clear: both;
      content: '';
    }

    .academic-profile-aside {
      float: right;
      width: 300px;
      margin: 82px 20px 20px;
      text-align: center;
    }

    .academic-profile-aside > img {
      width: 280px;
      height: 280px;
      margin-inline: auto;
      border: 2px solid rgba(255, 255, 255, .72);
      border-radius: 8px;
      object-fit: cover;
      box-shadow: 0 18px 50px rgba(0, 0, 0, .36);
    }

    .academic-social-links {
      display: flex;
      justify-content: center;
      gap: 14px;
      margin: 7px 0 14px;
    }

    .academic-social-links a {
      display: grid;
      width: 46px;
      height: 46px;
      place-items: center;
      border-radius: 8px;
      color: var(--text-soft);
      transition: color .2s ease, background .2s ease, transform .2s ease;
    }

    .academic-social-links a:hover {
      color: var(--text);
      background: rgba(255, 255, 255, .09);
      transform: translateY(-1px);
    }

    .academic-social-links svg {
      width: 30px;
      height: 30px;
      fill: currentColor;
    }

    .academic-document-links {
      display: flex;
      justify-content: center;
      gap: 8px;
      color: var(--text-soft);
      font-size: .88rem;
    }

    .academic-document-links a,
    .academic-timeline-content a {
      color: var(--signal);
      text-decoration: none;
    }

    .academic-document-links a:hover,
    .academic-timeline-content a:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .academic-profile-copy h1 {
      margin: 0 0 20px;
      color: var(--text);
      font-size: clamp(2.65rem, 6vw, 3.5rem);
      font-weight: 300;
      line-height: 1.1;
      letter-spacing: -.035em;
    }

    .academic-profile-copy h1 strong {
      font-weight: 720;
    }

    .academic-subtitle {
      max-width: 650px;
      margin: 0 0 30px;
      color: #f0f2ff;
      font-size: 1.1rem;
      font-weight: 650;
      line-height: 1.45;
    }

    .academic-description {
      max-width: 690px;
      font-size: 1rem;
      line-height: 1.75;
    }

    .academic-description p {
      margin: 0 0 20px;
    }

    .academic-section-rule {
      clear: both;
      margin-top: 30px;
      border-top: 2px solid rgba(255, 255, 255, .76);
    }

    .academic-research-section {
      position: relative;
      isolation: isolate;
      padding: 42px 0 10px;
    }

    .academic-research-section::before {
      position: absolute;
      z-index: -1;
      inset: 0 -44px;
      background:
        linear-gradient(rgba(3, 5, 14, .68), rgba(3, 6, 17, .82)),
        url('/images/academic/jwst-pillars.webp') right 12% top 80px / min(820px, 92vw) auto no-repeat;
      content: '';
      pointer-events: none;
    }

    .academic-timeline {
      position: relative;
      padding-left: 70px;
    }

    .academic-timeline::before {
      position: absolute;
      top: 10px;
      bottom: 0;
      left: 85px;
      width: 2px;
      background: rgba(255, 255, 255, .72);
      content: '';
    }

    .academic-timeline-item {
      position: relative;
      margin-bottom: 52px;
      scroll-margin-top: 108px;
    }

    .academic-timeline-item::before {
      position: absolute;
      top: 10px;
      left: 11px;
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--signal);
      box-shadow: 0 0 0 4px rgba(240, 204, 114, .14);
      content: '';
    }

    .academic-timeline-date {
      position: absolute;
      top: 5px;
      left: -70px;
      width: 55px;
      color: var(--text);
      font-size: .78rem;
      font-weight: 700;
      text-align: right;
      white-space: nowrap;
    }

    .academic-timeline-content {
      margin-left: 35px;
    }

    .academic-timeline-content h2 {
      margin: 0 0 8px;
      color: var(--text);
      font-size: 1.35rem;
      font-weight: 450;
      line-height: 1.35;
    }

    .academic-title-with-logo {
      position: relative;
      min-height: 48px;
      padding-right: 180px;
    }

    .academic-institution-logo {
      position: absolute;
      top: 50%;
      right: 10px;
      display: flex;
      width: 150px;
      align-items: center;
      justify-content: flex-end;
      padding: 6px 9px;
      border-radius: 6px;
      background: rgba(255, 255, 255, .9);
      transform: translateY(-50%);
    }

    .academic-institution-logo img {
      width: auto;
      max-width: 76px;
      max-height: 52px;
      object-fit: contain;
    }

    .academic-institution-logo img.wide {
      max-width: 128px;
    }

    .academic-institution-logo img.lab-wordmark {
      width: 150px;
      max-width: 150px;
      max-height: 46px;
    }

    .academic-institution {
      margin: 0 0 14px;
      color: var(--text-soft);
      font-size: .93rem;
      font-style: italic;
    }

    .academic-timeline-content ul {
      margin: 14px 0 20px;
      padding-left: 22px;
    }

    .academic-timeline-content li {
      margin-bottom: 8px;
      line-height: 1.65;
    }

    .academic-timeline-content > p {
      margin: 0 0 12px;
      line-height: 1.7;
    }

    .academic-media-module {
      margin: 24px 0;
    }

    .academic-media-module img {
      width: 100%;
      border: 2px solid rgba(255, 255, 255, .62);
      border-radius: 8px;
      background: #0a1025;
      box-shadow: 0 18px 48px rgba(0, 0, 0, .3);
    }

    .academic-media-module figcaption {
      margin-top: 9px;
      color: var(--text-soft);
      font-size: .86rem;
      line-height: 1.5;
    }

    .academic-publication-list {
      display: grid;
      margin-top: 18px;
      border-top: 1px solid rgba(255, 255, 255, .2);
    }

    .academic-publication-list a {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 4px 18px;
      padding: 20px 0;
      border-bottom: 1px solid rgba(255, 255, 255, .2);
      color: var(--text);
    }

    .academic-publication-list a:hover {
      text-decoration: none;
    }

    .academic-publication-list span {
      grid-row: 1 / span 2;
      color: var(--signal);
      font-size: .72rem;
      font-weight: 750;
      letter-spacing: .05em;
      text-transform: uppercase;
    }

    .academic-publication-list strong {
      font-size: 1.02rem;
      font-weight: 650;
    }

    .academic-publication-list small {
      color: var(--text-soft);
      font-size: .84rem;
      line-height: 1.5;
    }

    .academic-logo-strip {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: center;
      gap: 26px;
      margin-top: 28px;
      padding: 20px;
      border: 1px solid rgba(255, 255, 255, .24);
      border-radius: 8px;
      background: rgba(255, 255, 255, .9);
    }

    .academic-logo-strip img {
      width: auto;
      max-width: 128px;
      max-height: 58px;
      object-fit: contain;
    }

    .academic-contact-item {
      margin-bottom: 0;
    }

    .academic-image-credits {
      margin-top: 36px;
      padding-top: 16px;
      border-top: 1px solid rgba(255, 255, 255, .18);
      color: var(--text-soft);
      font-size: .73rem;
      line-height: 1.55;
    }

    .academic-page-index {
      position: fixed;
      z-index: 30;
    }

    .academic-page-index-toggle {
      display: none;
    }

    .academic-page-index-panel {
      position: fixed;
      top: 104px;
      left: max(12px, calc(50% - 710px));
      width: 140px;
      max-height: calc(100vh - 128px);
      overflow-y: auto;
      padding: 13px 10px 12px;
      border: 1px solid rgba(255, 255, 255, .2);
      border-radius: 8px;
      color: var(--text);
      background: rgba(5, 8, 21, .92);
      box-shadow: 0 14px 42px rgba(0, 0, 0, .34);
      backdrop-filter: blur(12px);
    }

    .academic-page-index-panel > p {
      margin: 0 6px 8px;
      color: var(--signal);
      font-size: .64rem;
      font-weight: 800;
      letter-spacing: .1em;
      text-transform: uppercase;
    }

    .academic-page-index-panel ol {
      display: grid;
      gap: 2px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    .academic-page-index-panel a {
      position: relative;
      display: grid;
      grid-template-columns: 24px 1fr;
      min-height: 34px;
      align-items: center;
      padding: 5px 5px 5px 8px;
      color: var(--text-soft);
      font-size: .7rem;
      font-weight: 650;
      line-height: 1.35;
    }

    .academic-page-index-panel a::before {
      position: absolute;
      top: 7px;
      bottom: 7px;
      left: 0;
      width: 3px;
      background: transparent;
      content: '';
    }

    .academic-page-index-panel a span {
      color: #9ea8c8;
      font-size: .61rem;
    }

    .academic-page-index-panel a:hover,
