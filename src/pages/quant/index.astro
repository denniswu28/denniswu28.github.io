---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import CapabilityExplorer from '../../components/CapabilityExplorer.astro';
import { experiences, independentProjects } from '../../data/site';
---

<BaseLayout title="Quantitative Research and Trading" description="Production-focused quantitative research across forecasting, market making, execution, market data, monitoring, and risk.">
  <div class="shell">
    <PageIntro eyebrow="Profile / production markets" title="Quantitative Research and Trading" description="I build short-horizon forecasting, execution, market-making, and research infrastructure from data and simulation through monitoring and risk." />
  </div>

  <section class="section" id="experience">
    <div class="shell">
      <div class="section-heading section-heading-compact">
        <div><p class="eyebrow">Experience</p><h2>Research connected to live systems.</h2></div>
      </div>
      <div class="entry-list">
        {experiences.map((experience) => (
          <article class="experience-card" id={experience.id}>
            <div class="experience-meta">
              <strong>{experience.organization}</strong>
              <span>{experience.dates}</span><br />
              <span>{experience.location}</span>
            </div>
            <div class="experience-body">
              <h2>{experience.role}</h2>
              <p>{experience.mandate}</p>
              <ul class="impact-list">{experience.accomplishments.map((item) => <li>{item}</li>)}</ul>
              <div class="tech-row">{experience.technologies.map((technology) => <span>{technology}</span>)}</div>
              <div class="button-row"><a class="button button-secondary" href={experience.evidenceHref}>Learn more</a></div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="capabilities">
    <div class="shell">
      <div class="section-heading section-heading-compact">
        <div><h2>Capabilities</h2></div>
      </div>
      <CapabilityExplorer />
    </div>
  </section>

  <section class="section" id="independent-projects">
    <div class="shell">
      <div class="section-heading section-heading-compact">
        <div><h2>Independent Systems Research</h2></div>
      </div>
      <div class="independent-projects" data-independent-projects>
        <div class="independent-project-buttons">
          {independentProjects.map((project) => (
            <button
              class="independent-project-button"
              type="button"
              id={`independent-button-${project.id}`}
              aria-expanded="false"
              aria-controls={`independent-panel-${project.id}`}
              data-independent-button={project.id}
            >
              <span class="eyebrow">{project.kicker}</span>
              <strong>{project.title}</strong>
              <small>{project.summary}</small>
              <span class="independent-project-arrow" aria-hidden="true">+</span>
            </button>
          ))}
        </div>
        <div class="independent-project-panels" aria-live="polite">
          {independentProjects.map((project) => (
            <article
              class="independent-project-panel"
              id={`independent-panel-${project.id}`}
              aria-labelledby={`independent-button-${project.id}`}
              data-independent-panel={project.id}
              hidden
            >
              <h3>{project.title}</h3>
              <ul class="impact-list">{project.bullets.map((bullet) => <li>{bullet}</li>)}</ul>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.querySelectorAll<HTMLElement>('[data-independent-projects]').forEach((projectGroup) => {
      const buttons = Array.from(projectGroup.querySelectorAll<HTMLButtonElement>('[data-independent-button]'));
      const panels = Array.from(projectGroup.querySelectorAll<HTMLElement>('[data-independent-panel]'));

      buttons.forEach((button) => {
        const id = button.dataset.independentButton;
        const panel = panels.find((candidate) => candidate.dataset.independentPanel === id);
        if (!id || !panel) return;
        button.addEventListener('click', () => {
          const willOpen = button.getAttribute('aria-expanded') !== 'true';
          buttons.forEach((candidate) => {
            candidate.setAttribute('aria-expanded', 'false');
            candidate.classList.remove('is-active');
          });
          panels.forEach((candidate) => { candidate.hidden = true; });

          if (willOpen) {
            button.setAttribute('aria-expanded', 'true');
            button.classList.add('is-active');
            panel.hidden = false;
          }
        });
      });
    });
  </script>
</BaseLayout>
