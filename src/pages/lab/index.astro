---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageIntro from '../../components/PageIntro.astro';
import { filterPublished } from '../../lib/content';

const experiments = filterPublished(await getCollection('experiments'));
const planned = [
  ['02', 'Grid Market-Making Simulator', 'Recorded order-book replay with inventory, fees, latency, and adverse-selection controls.'],
  ['03', 'Crypto Microstructure Browser', 'Trade, spread, depth, imbalance, and lead–lag inspection.'],
  ['04', 'Prediction Market Observatory', 'Empirical liquidity, fee, participant, and resolution behavior research.'],
  ['05', 'Research Replications', 'Adapt published market-structure claims to transparent crypto datasets.']
] as const;
---

<BaseLayout title="Quant Lab" description="Inspectable quantitative experiments organized from question and data through method, results, limitations, and code.">
  <div class="shell"><PageIntro eyebrow="Application-like evidence" title="Quant Lab" description="Every experiment follows Question → Data → Method → Parameters → Results → Limitations → Code. Reproducible replay comes before unreliable live infrastructure." /></div>
  <section class="section">
    <div class="shell">
      <div class="entry-list">
        {experiments.map((experiment) => (
          <a class="experiment-card" href={`/lab/${experiment.data.slug}/`}>
            <span class="experiment-number">01</span>
            <div><h2>{experiment.data.title}</h2><p>{experiment.data.summary}</p></div>
            <span class="state-pill">Case study</span>
          </a>
        ))}
        {planned.map(([number, title, description]) => (
          <article class="experiment-card" data-state="planned">
            <span class="experiment-number">{number}</span>
            <div><h2>{title}</h2><p>{description}</p></div>
            <span class="state-pill">Planned</span>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
