---
import BaseLayout from '../layouts/BaseLayout.astro';
import { homeTopics, site } from '../data/site';
---

<BaseLayout title={site.name} description={site.description}>
  <section class="hero">
    <div class="shell hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Quantitative research · production systems</p>
        <h1>Tianrui Wu</h1>
        <p class="lede">I am Tianrui Wu, an undergraduate student in physics and math at the University of Arizona. I work on galaxy clustering and cosmology, and I also work as a quantitative researcher and systematic trader, building forecasting, execution, and market-making systems using machine learning, higher-frequency systems, and statistical inference.</p>
        <div class="button-row">
          <a class="button" href="/quant/">View Quant Profile</a>
          <a class="button button-quiet" href={site.resume} target="_blank" rel="noopener">Download Resume</a>
        </div>
      </div>
      <aside class="hero-profile">
        <img src="/images/portrait.jpg" alt="Portrait of Tianrui Wu" />
        <blockquote>I use facts as evidence, and I use logic as pathways.</blockquote>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section-heading section-heading-compact">
        <div><h2>Choose the topic you need.</h2></div>
      </div>
      <nav class="topic-grid" aria-label="Explore the site">
        {homeTopics.map((topic) => (
          <a class="topic-link" href={topic.href}>
            <span>{topic.title}</span>
            <span aria-hidden="true">→</span>
          </a>
        ))}
      </nav>
    </div>
  </section>
</BaseLayout>
