---
import { navigation, site } from '../data/site';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  image,
  type = 'website',
  noindex = false,
  schema
} = Astro.props;
const pageTitle = title === site.name ? `${site.name} | ${site.title}` : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const imageUrl = new URL(image ?? site.socialImage, Astro.site ?? Astro.url.origin);
const currentPath = Astro.url.pathname;
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.fullName,
  alternateName: site.name,
  url: site.url,
  jobTitle: site.title,
  sameAs: [site.github, site.linkedin]
};
const structuredData = schema ? [personSchema, ...(Array.isArray(schema) ? schema : [schema])] : [personSchema];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content={String(site.socialImageWidth)} />
    <meta property="og:image:height" content={String(site.socialImageHeight)} />
    <meta property="og:image:alt" content={site.socialImageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:image:alt" content={site.socialImageAlt} />
    <meta name="theme-color" content="#05080d" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📈</text></svg>" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Oxanium:wght@500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <header class="site-header">
      <div class="shell header-inner">
        <a class="brand" href="/" aria-label="Tianrui Wu, home">
          <span class="brand-mark" aria-hidden="true">TW</span>
          <span>{site.name}</span>
        </a>
        <nav class="desktop-nav" aria-label="Primary navigation">
          {navigation.map((item) => (
            <a href={item.href} aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}>{item.label}</a>
          ))}
        </nav>
        <a class="button button-small resume-action" href={site.resume} target="_blank" rel="noopener">Resume PDF <span aria-hidden="true">↗</span></a>
        <details class="mobile-menu">
          <summary aria-label="Open navigation">Menu</summary>
          <nav aria-label="Mobile navigation">
            {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
            <a href={site.resume} target="_blank" rel="noopener">Resume PDF</a>
          </nav>
        </details>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer" id="contact">
      <div class="shell footer-grid">
        <div>
          <p class="eyebrow">Research · systems · evidence</p>
        </div>
        <div class="footer-links">
          <a href={`mailto:${site.email}`}>{site.email}</a>
          <a href={site.github} target="_blank" rel="noopener">GitHub</a>
          <a href={site.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
      <div class="shell footer-bottom">
        <span>© {new Date().getFullYear()} {site.fullName}</span>
        <span>Historical research is not investment advice.</span>
      </div>
    </footer>
    <script>
      const root = document.documentElement;
      const updatePointer = (event: PointerEvent) => {
        root.style.setProperty('--pointer-x', `${event.clientX}px`);
        root.style.setProperty('--pointer-y', `${event.clientY}px`);
      };
      window.addEventListener('pointermove', updatePointer, { passive: true });

      document.querySelectorAll<HTMLDetailsElement>('.mobile-menu').forEach((menu) => {
        menu.querySelectorAll('a').forEach((link) => link.addEventListener('click', () => menu.removeAttribute('open')));
      });
    </script>
    {currentPath === '/' && (
      <script is:inline>
        const legacyRoutes = {
          '#quant-profile': '/lab/trading-systems-execution/',
          '#experience': '/quant/#experience',
          '#projects': '/quant/#independent-projects',
          '#research': '/academic/',
          '#publications': '/academic/#publications',
          '#skills': '/quant/#capabilities',
          '#education': '/academic/#education',
          '#distinctions': '/academic/#recognition'
        };
        const destination = legacyRoutes[window.location.hash];
        if (destination) window.location.replace(destination);
      </script>
    )}
  </body>
</html>
